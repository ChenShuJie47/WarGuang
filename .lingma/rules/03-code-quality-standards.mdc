## 一、GDScript 语法规范

### 1.1 Godot 4 API 强制要求 ⭐⭐⭐
```gdscript
# ✅ 正确使用 Godot 4 API
set_process_mode(PROCESS_MODE_ALWAYS)      # ❌ 旧：set_process(true)
get_tree().root                             # ❌ 旧：get_tree().get_root()
node.queue_free()                           # ❌ 旧：queue_delete()
position = Vector2(100, 200)                # ❌ 旧：set_pos(Vector2)
scale = Vector2(2, 2)                       # ❌ 旧：set_scale(Vector2)
rotation = deg_to_rad(45)                   # ❌ 旧：set_rotation(deg_to_rad(45))
%UniqueNodeName                             # ❌ 旧：get_node("UniqueNodeName")
await get_tree().create_timer(1.0).timeout  # ❌ 旧：yield(...)

# 类型标注必须完整
var health: int = 100                       # ✅ 必须标注类型
func take_damage(amount: int) -> void:      # ✅ 必须标注参数和返回类型
    pass
```

### 1.2 变量声明规范
```gdscript
# 导出变量（配置用）
@export var speed: float = 200.0            # ✅ Inspector 可见
@export_range(0, 100) var health: int = 100

# 普通变量（内部使用）
var _internal_counter: int = 0              # ✅ 私有变量加下划线
var is_moving: bool = false

# 常量
const MAX_SPEED: float = 300.0              # ✅ 全大写 + 下划线
const PLAYER_NAME: String = "Warma"

# 运行时计算的变量（不应设为@export）
var effective_speed: float                  # ✅ 内部变量，运行时计算
```

### 1.3 函数定义规范
```gdscript
# 生命周期函数
func _ready() -> void:
    pass

func _process(delta: float) -> void:
    pass

func _physics_process(delta: float) -> void:
    pass

# 自定义函数
## 对玩家造成伤害
## @param amount 伤害值
## @return 是否成功造成伤害
func take_damage(amount: int) -> bool:
    if amount < 0:
        return false
    
    health -= amount
    return true

# 信号处理函数
func _on_button_pressed() -> void:          # ✅ 下划线前缀
    pass
```

