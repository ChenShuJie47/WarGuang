## 七、测试友好性规范

### 7.1 可测试性设计原则
```gdscript
# ✅ 将核心逻辑提取为独立函数
# ❌ 坏设计：逻辑耦合在 _physics_process 中
func _physics_process(delta: float) -> void:
    velocity.y += gravity * delta
    if velocity.y > max_fall_speed:
        velocity.y = max_fall_speed
    move_and_slide()

# ✅ 好设计：逻辑可独立测试
func _physics_process(delta: float) -> void:
    _apply_gravity(delta)
    _clamp_velocity()
    move_and_slide()

func apply_gravity(delta: float) -> void:  # 可独立测试
    velocity.y += gravity * delta

func clamp_velocity() -> void:  # 可独立测试
    if velocity.y > max_fall_speed:
        velocity.y = max_fall_speed
```

### 7.2 调试钩子设计
```gdscript
# ✅ 提供调试命令接口
func _unhandled_input(event: InputEvent) -> void:
    if OS.is_debug_build():
        if event.is_action_pressed("debug_god_mode"):
            is_invincible = true
        if event.is_action_pressed("debug_unlock_all"):
            _unlock_all_abilities()

func _unlock_all_abilities() -> void:
    Global.unlocked_abilities = {
        "dash": true,
        "double_jump": true,
        # ... 所有能力
    }
```

