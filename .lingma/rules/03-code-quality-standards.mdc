## 四、错误处理与防御性编程

### 4.1 null 检查强制要求 ⭐⭐⭐
```gdscript
# ✅ 外部引用使用前必须检查
@onready var player: Player = $Player

func damage_player(amount: int) -> void:
    if player == null:  # 必须检查！
        print("错误：玩家节点不存在")
        return
    
    player.take_damage(amount)

# ✅ 跨场景引用必须检查
func on_npc_interaction(npc: NPC) -> void:
    if not is_instance_valid(npc):  # 必须检查！
        return
    
    npc.start_dialogue()
```

### 4.2 数组和字典安全访问
```gdscript
# ✅ 数组访问前检查边界
if index >= 0 and index < items.size():
    var item = items[index]

# ✅ 字典访问使用 has() 验证
if data.has("player_health"):
    Global.player_health = data["player_health"]
else:
    print("警告：存档缺少 player_health 字段")
```

### 4.3 信号连接验证
```gdscript
# ✅ 连接前检查接收方
func connect_signals() -> void:
    if is_instance_valid($UI/HealthBar):
        $UI/HealthBar.health_changed.connect(_on_health_changed)
    else:
        print("错误：血条节点不存在")
```

