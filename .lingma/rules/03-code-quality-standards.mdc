## 六、代码可读性规范

### 6.1 命名一致性原则
```gdscript
# ✅ 变量命名：snake_case
var player_health: int
var move_speed: float

# ✅ 函数命名：snake_case
func take_damage(amount: int) -> void:
    pass

# ✅ 类名/类型名：PascalCase
class_name PlayerCharacter
extends CharacterBody2D

# ✅ 常量命名：CONSTANT_CASE
const MAX_HEALTH: int = 100
const GRAVITY_ACCELERATION: float = 980.0

# ✅ 私有成员：下划线前缀
var _internal_counter: int = 0
func _private_helper() -> void:
    pass
```

### 6.2 魔法数字消除原则
```gdscript
# ❌ 坏代码：魔法数字
func jump() -> void:
    velocity.y = -400.0
    invincible_time = 0.5

# ✅ 好代码：具名常量
const JUMP_STRENGTH: float = -400.0
const INVINCIBLE_DURATION: float = 0.5

func jump() -> void:
    velocity.y = JUMP_STRENGTH
    is_invincible = true
    invincible_timer = INVINCIBLE_DURATION
```

### 6.3 函数单一职责原则
```gdscript
# ❌ 坏代码：臃肿函数
func update_player() -> void:
    # 处理输入
    var input_dir = Input.get_axis("left", "right")
    # 应用移动
    velocity.x = input_dir * move_speed
    # 应用重力
    velocity.y += gravity * delta
    # 更新动画
    if velocity.x != 0:
        animated_sprite.play("MOVE")
    # 处理碰撞
    if is_on_wall():
        velocity.x = 0
    # ... 还有 50 行代码

# ✅ 好代码：拆分小函数
func update_player() -> void:
    _handle_input()
    _apply_movement()
    _apply_gravity()
    _update_animation()
    _handle_collisions()

func _handle_input() -> void:
    var input_dir = Input.get_axis("left", "right")
    # ...

func _apply_movement() -> void:
    var input_dir = Input.get_axis("left", "right")
    velocity.x = input_dir * move_speed
```

