## 五、性能优化规范

### 5.1 高频函数中的禁止行为
```gdscript
# ❌ 禁止在 _process/_physics_process 中：
func _process(delta: float) -> void:
    print("调试信息")              # ❌ 每帧打印
    var temp = []                  # ❌ 创建临时数组
    temp.append(1)                 # ❌ 动态分配内存
    get_node("Enemy").die()        # ❌ 每帧查找节点

# ✅ 正确做法：
var _debug_timer: float = 0.0
var _cached_enemies: Array = []

func _ready() -> void:
    _cached_enemies = get_tree().get_nodes_in_group("enemies")  # 缓存引用

func _process(delta: float) -> void:
    _debug_timer += delta
    if _debug_timer > 1.0:       # 每秒打印一次
        print("FPS: ", Engine.get_frames_per_second())
        _debug_timer = 0.0
```

### 5.2 对象池使用建议
```gdscript
# 适用对象池的场景：
# 1. 频繁创建销毁的对象（残影、粒子、子弹）
# 2. 实例化开销大的对象（复杂敌人）
# 3. 需要精确控制生命周期的对象

# 简单对象池示例：
var _projectile_pool: Array[Projectile] = []

func spawn_projectile(position: Vector2) -> Projectile:
    if _projectile_pool.is_empty():
        var proj = preload("res://Scenes/Projectile.tscn").instantiate() as Projectile
        add_child(proj)
        return proj
    else:
        var proj = _projectile_pool.pop_back()
        proj.global_position = position
        proj.visible = true
        return proj
```

