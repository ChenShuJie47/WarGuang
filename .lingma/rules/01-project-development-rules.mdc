## 二、Autoload 管理器使用规范

### 2.1 场景切换时必须重置 Autoload 状态 ⭐⭐⭐
```gdscript
# SceneManager.gd switch_scene() 中必须包含：
func switch_scene(scene_path: String) -> void:
    # 1. 渐黑转场
    await FadeManager.fade_out(0.4)
    
    # 2. 重置对话状态（必须！）
    DialogueSystem.reset()
    
    # 3. 切换场景
    var err = get_tree().change_scene_to_file(scene_path)
    
    # 4. 渐出转场
    await FadeManager.fade_in(0.4)
```

### 2.2 多存档数据完全隔离原则 ⭐⭐⭐
```gdscript
# Global.gd initialize_new_game() 中必须重置：
func initialize_new_game() -> void:
    # 基础数据
    player_health = 3
    max_player_health = 3
    player_coins = 0
    
    # 能力解锁状态（必须重置！）
    unlocked_abilities = {
        "dash": false,
        "double_jump": false,
        "glide": false,
        "wall_grip": false,
        "super_dash": false
    }
    
    # 挑战状态（必须重置！）
    maniac_challenge_completed = false
    maniac_stage_one_completed = false
    
    # 任务进度（必须重置！）
    TaskManager.reset_all_tasks()
```

### 2.3 存档数据深拷贝规范
```gdscript
# SaveManager.gd 中必须使用：
func get_save_data(slot_index: int) -> Dictionary:
    var data = {
        "player_health": Global.player_health,
        "unlocked_abilities": Global.unlocked_abilities.duplicate(true),  # 必须深拷贝
        "task_records": TaskManager.get_task_records().duplicate(true)    # 必须深拷贝
    }
    return data
```

### 2.4 加载存档字段验证规范
```gdscript
# SaveManager.gd load_save_data() 中必须验证：
func load_save_data(data: Dictionary) -> void:
    if data.has("player_health"):
        Global.player_health = data["player_health"]
    
    if data.has("unlocked_abilities"):
        Global.unlocked_abilities = data["unlocked_abilities"].duplicate(true)
    
    # 兼容旧存档：如果缺少字段，使用默认值
    if not data.has("maniac_challenge_completed"):
        Global.maniac_challenge_completed = false
```

