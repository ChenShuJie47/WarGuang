[internationalization]

locale/translations_pot_files=PackedStringArray("res://Assets/Dialogues/DialoguesNPC4.dialogue", "res://Assets/Dialogues/ManiacDialogue.dialogue", "res://Assets/Dialogues/MasterDialogue.dialogue", "res://Assets/Dialogues/MerchantDialogue.dialogue")

[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="Ground"
2d_physics/layer_3="Wall"
2d_physics/layer_4="JumpBox"
2d_physics/layer_5="HurtBox"
2d_physics/layer_6="Good"

[physics]

common/physics_interpolation=false
common/max_physics_ticks_per_second=120

[phantom_camera]

tips/show_jitter_tips=false

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
